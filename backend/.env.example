# --- Django ----------------------------------------------------------------
# Cambiar por una clave secreta real (p.ej. `python -c "import secrets; print(secrets.token_urlsafe(50))"`).
DJANGO_SECRET_KEY=dev-insecure-change-me
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS -------------------------------------------------------------------
# Orígenes permitidos para consumir la API (el frontend Vite).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Clerk ------------------------------------------------------------------
# "Frontend API URL" del dashboard de Clerk (= claim `iss` del token).
CLERK_ISSUER=https://tu-app-xxxx.clerk.accounts.dev
# Orígenes permitidos en el claim `azp` del token (el frontend).
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# --- Bonus 2: emisión asíncrona + webhook (SII simulado) --------------------
# Endpoint externo al que se solicita la emisión del documento.
SII_EMISION_URL=https://eoej5sf0r8zkoh2.m.pipedream.net
# Base pública para el callbackUrl del webhook. En local con ngrok, poné la URL
# del túnel (ej: https://xxxx.ngrok-free.app); en prod, el dominio del backend.
PUBLIC_BASE_URL=http://localhost:8000
# Secreto para autenticar el webhook (se manda como ?token= en el callbackUrl).
# Generá uno con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SII_WEBHOOK_SECRET=

# --- Postgres (LOCAL / Docker) ----------------------------------------------
# Deben coincidir con las del docker-compose.yml. HOST=localhost porque
# Django corre nativo y se conecta al Postgres expuesto por Docker en :5432.
POSTGRES_DB=carvuk
POSTGRES_USER=carvuk
POSTGRES_PASSWORD=carvuk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Local no tiene TLS; "prefer" se conecta igual. (Ver settings.py)
POSTGRES_SSLMODE=prefer
POSTGRES_CONN_MAX_AGE=60

# --- Postgres (SUPABASE) ----------------------------------------------------
# Para migrar a Supabase, comentá el bloque LOCAL de arriba y descomentá este,
# rellenando con los valores del dashboard: Project -> Connect -> Session Pooler.
#   POSTGRES_DB=postgres
#   POSTGRES_USER=postgres.<project-ref>        # ej: postgres.abcdxyz123
#   POSTGRES_PASSWORD=<tu-database-password>    # la que definiste al crear el proyecto
#   POSTGRES_HOST=aws-0-<region>.pooler.supabase.com
#   POSTGRES_PORT=5432                           # 5432 = Session Pooler (recomendado)
#   POSTGRES_SSLMODE=require                     # Supabase exige TLS
#   POSTGRES_CONN_MAX_AGE=60
